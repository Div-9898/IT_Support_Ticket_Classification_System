# Application Configuration
APP_NAME=IT Support Ticket Classification System
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# Server Configuration
HOST=localhost
PORT=8000
WORKERS=4
RELOAD=True

# Database Configuration
DATABASE_URL=sqlite:///./it_support_tickets.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/it_support_db
DATABASE_ECHO=False

# Machine Learning Configuration
ML_MODEL_PATH=./models/
HUGGINGFACE_MODEL_NAME=distilbert-base-uncased
MAX_SEQUENCE_LENGTH=512
BATCH_SIZE=32
LEARNING_RATE=2e-5
EPOCHS=3

# CUDA Configuration
CUDA_VISIBLE_DEVICES=0
USE_GPU=True
MIXED_PRECISION=True

# Security Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=./logs/app.log
ENABLE_FILE_LOGGING=True

# API Configuration
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
ENABLE_DOCS=True
DOCS_URL=/docs
REDOC_URL=/redoc

# Feature Flags
ENABLE_ASYNC_PROCESSING=True
ENABLE_CACHING=True
ENABLE_METRICS=True
ENABLE_RATE_LIMITING=True

# External Services
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Monitoring
PROMETHEUS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# Data Processing
DATA_PREPROCESSING_BATCH_SIZE=1000
TEXT_PREPROCESSING_WORKERS=4
FEATURE_EXTRACTION_WORKERS=2

# Model Training
TRAIN_TEST_SPLIT=0.8
VALIDATION_SPLIT=0.1
RANDOM_SEED=42
MODEL_SAVE_INTERVAL=1000
EARLY_STOPPING_PATIENCE=5

# Cache Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
CACHE_PREFIX=it_support_

# File Storage
UPLOAD_FOLDER=./uploads/
MAX_CONTENT_LENGTH=16777216  # 16MB
ALLOWED_EXTENSIONS=.txt,.csv,.json,.xlsx
